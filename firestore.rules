rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Existing collections — unchanged from what's currently live ──
    // Left exactly as permissive as before so the client portal keeps
    // working with zero changes. (Worth tightening later by extending
    // the same Netlify Identity -> Firebase Auth bridge to clients too,
    // but that's a separate project from tonight's rep dashboard work.)
    match /messages/{messageId} {
      allow read, write: if true;
    }
    match /reports/{clientKey}/months/{monthId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    match /workcompleted/{clientKey}/months/{monthId} {
      allow read, write: if true;
    }

    // ── Leads table — real enforcement, via the Netlify -> Firebase
    // custom-token auth bridge (mint-firebase-token) ──
    match /leads/{leadId} {
      allow read: if request.auth != null
                  && (request.auth.token.role == 'sales_rep' || request.auth.token.role == 'admin');

      allow create: if request.auth != null
                    && (request.auth.token.role == 'sales_rep' || request.auth.token.role == 'admin')
                    && request.resource.data.addedByEmail == request.auth.token.email;

      allow update: if request.auth != null
                    && (request.auth.token.role == 'admin'
                        || resource.data.addedByEmail == request.auth.token.email);

      allow delete: if request.auth != null && request.auth.token.role == 'admin';

      match /comments/{commentId} {
        allow read: if request.auth != null
                    && (request.auth.token.role == 'sales_rep' || request.auth.token.role == 'admin');

        allow create: if request.auth != null
                      && (request.auth.token.role == 'sales_rep' || request.auth.token.role == 'admin')
                      && request.resource.data.author == request.auth.token.email;

        allow update, delete: if false;
      }
    }

    // ── Team discussion thread — any rep/admin can read and post ──
    match /teamThread/{monthKey}/messages/{msgId} {
      allow read: if request.auth != null
                  && (request.auth.token.role == 'sales_rep' || request.auth.token.role == 'admin');

      allow create: if request.auth != null
                    && (request.auth.token.role == 'sales_rep' || request.auth.token.role == 'admin')
                    && request.resource.data.authorEmail == request.auth.token.email;

      allow update, delete: if false;
    }

    // ── Private rep <-> Joseph messages ──
    match /repMessages/{msgId} {
      // Reps can only see their own thread; admin sees all
      allow read: if request.auth != null
                  && (request.auth.token.role == 'admin'
                      || resource.data.repEmail == request.auth.token.email);

      allow create: if request.auth != null
                    && (
                      // Rep sending their own message
                      (request.auth.token.role == 'sales_rep' && request.resource.data.repEmail == request.auth.token.email)
                      // Admin replying into any rep's thread
                      || request.auth.token.role == 'admin'
                    );

      allow update, delete: if false;
    }

    // ── Rep training progress — doc ID is the rep's lowercased email,
    // so ownership is just an equality check against the path itself ──
    match /trainingProgress/{repEmail} {
      allow read: if request.auth != null
                  && (request.auth.token.role == 'admin'
                      || request.auth.token.email == repEmail);
      allow write: if request.auth != null
                   && (request.auth.token.role == 'admin'
                       || request.auth.token.email == repEmail);
    }
  }
}
